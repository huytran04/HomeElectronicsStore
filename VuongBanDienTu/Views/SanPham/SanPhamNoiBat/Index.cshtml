@model IEnumerable<VuongBanDienTu.Models.SanPham>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model.Take(4))
        {
            <div class="prod-card bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all cursor-pointer relative group border border-slate-100 flex flex-col h-full" onclick="location.href='@Url.Action("ChiTiet", "SanPham", new { id = item.MaSanPham })'">
                <div class="h-44 sm:h-52 flex items-center justify-center p-4 overflow-hidden relative">
                    @if (!string.IsNullOrEmpty(item.AnhChinh))
                    {
                        <img src="~/Content/Images/Products/@item.AnhChinh" alt="@item.TenSanPham" class="main-img max-h-full object-contain transition-all duration-500 group-hover:scale-105 @(item.HinhAnhSanPhams != null && item.HinhAnhSanPhams.Any() ? "group-hover:opacity-0" : "")" />
                        if (item.HinhAnhSanPhams != null && item.HinhAnhSanPhams.Any())
                        {
                            var secondaryImg = item.HinhAnhSanPhams.First().DuongDanAnh;
                            <img src="~/Content/Images/Gallery/@secondaryImg" alt="@item.TenSanPham" class="secondary-img absolute inset-0 m-auto max-h-full object-contain opacity-0 group-hover:opacity-100 transition-all duration-500 scale-95 group-hover:scale-105" />
                        }
                    }
                    else
                    {
                        <div class="flex flex-col items-center gap-1">
                            <i class="fa fa-image text-slate-300 text-4xl"></i>
                            <span class="text-[10px] text-slate-400 uppercase font-black">No Image</span>
                        </div>
                    }
                </div>
                <div class="px-4 pb-4 flex-1 flex flex-col">
                    <h3 class="text-xs font-medium text-slate-700 line-clamp-2 h-9 mb-1 leading-tight group-hover:text-primary transition-colors">@(string.IsNullOrEmpty(item.TenSanPham) ? "Sản phẩm chưa có tên" : item.TenSanPham)</h3>
                    
                    <div class="flex flex-col gap-0.5 mb-3">
                        <div class="text-sm font-bold text-primary">@(item.GiaBan > 0 ? item.GiaBan.ToString("N0") + "₫" : "Liên hệ")</div>
                        @if (item.GiaBan > 1000000) {
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] text-slate-400 line-through">@((item.GiaBan * 1.2m).ToString("N0"))₫</span>
                                <span class="bg-primary text-white text-[9px] font-black px-1 py-0.2 rounded">-15%</span>
                            </div>
                        }
                    </div>

                    <div class="space-y-0.5 text-[10px] text-slate-400 font-medium h-12 overflow-hidden mb-2">
                        @if (!string.IsNullOrEmpty(item.ThongSoKyThuat))
                        {
                            var specs = item.ThongSoKyThuat.Split(new[] { '\n', '\r', ';', '|' }, StringSplitOptions.RemoveEmptyEntries);
                            foreach (var spec in specs.Take(3))
                            {
                                <div class="truncate">• @spec.Trim()</div>
                            }
                        }
                        else
                        {
                            <div>Đang cập nhật thông số...</div>
                            <div>Nhà sản xuất: @(item.DanhMuc != null ? item.DanhMuc.TenDanhMuc : "K-Shop")</div>
                        }
                    </div>

                    <div class="mt-auto pt-3">
                        <div class="flex items-center gap-1.5 text-[10px] text-blue-600 font-bold">
                            <i class="fa fa-circle-plus"></i> Thêm vào so sánh
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-span-full py-16 text-center bg-white rounded-xl shadow-sm border-2 border-dashed border-slate-100">
            <i class="fa fa-star text-slate-200 text-5xl mb-4 block"></i>
            <p class="text-slate-400 font-medium text-sm">Đang cập nhật sản phẩm nổi bật...</p>
        </div>
    }
</div>
