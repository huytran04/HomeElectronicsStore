@model IEnumerable<VuongBanDienTu.Models.GioHang>

@{
    ViewBag.Title = "Giỏ hàng của bạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-white border-b border-slate-200">
    <div class="max-w-screen-xl mx-auto px-4 py-8">
        <h1 class="text-3xl font-black text-slate-900 uppercase tracking-tight flex items-center gap-4">
            <i class="fa fa-shopping-basket text-primary"></i>
            Giỏ hàng của bạn
            @if (Model != null && Model.Any())
            {
                <span class="text-sm font-bold text-slate-400 bg-slate-100 px-3 py-1 rounded-full ml-2">@(Model.Sum(n => n.SoLuong) ?? 0) sản phẩm</span>
            }
        </h1>
    </div>
</div>

<main class="max-w-screen-xl mx-auto px-4 py-12">
    @if (TempData["Error"] != null)
    {
        <div class="mb-8 p-4 bg-red-50 border border-red-100 rounded-2xl flex items-center gap-3 text-primary text-sm font-black uppercase tracking-tight animate-bounce">
            <i class="fa fa-triangle-exclamation"></i>
            @TempData["Error"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="py-24 text-center bg-white rounded-[3rem] shadow-sm border border-slate-100 max-w-2xl mx-auto">
            <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-8">
                <i class="fa fa-shopping-basket text-slate-200 text-4xl"></i>
            </div>
            <h2 class="text-2xl font-black text-slate-800 mb-4">Giỏ hàng của bạn đang trống</h2>
            <p class="text-slate-400 mb-10 px-8">Hãy chọn cho mình những sản phẩm điện máy ưng ý nhất tại hệ thống của chúng tôi.</p>
            <a href="@Url.Action("Index", "SanPham")" class="inline-flex items-center gap-3 px-10 py-4 bg-primary text-white rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-red-100 hover:bg-primary-dark hover:-translate-y-1 transition-all">
                <i class="fa fa-shopping-cart"></i>
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Cart Items List -->
            <div class="lg:col-span-8 space-y-4">
                @foreach (var item in Model)
                {
                    <div class="bg-white rounded-3xl border border-slate-100 p-6 flex items-center gap-6 hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-500 cart-item" data-id="@item.MaSanPham">
                        <div class="w-24 h-24 bg-slate-50 rounded-2xl p-2 flex-shrink-0 overflow-hidden">
                            <img src="~/Content/Images/Products/@item.SanPham.AnhChinh" class="w-full h-full object-contain">
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between gap-4 mb-2">
                                <a href="@Url.Action("ChiTiet", "SanPham", new { id = item.MaSanPham })" class="text-lg font-black text-slate-800 hover:text-primary transition-colors truncate">@item.SanPham.TenSanPham</a>
                                <a href="@Url.Action("Xoa", "GioHang", new { id = item.MaSanPham })" class="text-slate-300 hover:text-primary p-2 transition-colors">
                                    <i class="fa fa-trash-can"></i>
                                </a>
                            </div>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center bg-slate-100 rounded-xl p-1">
                                    <button class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-primary transition-colors" onclick="updateQuantity(@item.MaSanPham, -1)"><i class="fa fa-minus text-[10px]"></i></button>
                                    <span class="w-10 text-center font-bold text-slate-800 qty-val">@item.SoLuong</span>
                                    <button class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-primary transition-colors" onclick="updateQuantity(@item.MaSanPham, 1)"><i class="fa fa-plus text-[10px]"></i></button>
                                </div>
                                <div class="text-right">
                                    <p class="text-xs text-slate-400 font-bold">Đơn giá: @item.SanPham.GiaBan.ToString("N0")₫</p>
                                    <p class="text-xl font-black text-primary italic item-total">@(((item.SoLuong ?? 0) * item.SanPham.GiaBan).ToString("N0"))₫</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <a href="@Url.Action("Index", "SanPham")" class="inline-flex items-center gap-2 text-primary font-black uppercase tracking-widest text-xs hover:gap-4 transition-all py-4">
                    <i class="fa fa-arrow-left"></i> Tiếp tục mua sắm
                </a>
            </div>

            <!-- Summary Sidebar -->
            <div class="lg:col-span-4">
                <div class="bg-white rounded-3xl border border-slate-100 p-8 sticky top-28 shadow-sm">
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-6 pb-4 border-b border-slate-50">Tạm tính</h3>
                    
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-sm text-slate-500 font-medium">
                            <span>Giá trị hàng hóa</span>
                            <span class="text-slate-800 font-bold summary-total">@(((decimal)(ViewBag.TongTien ?? 0m)).ToString("N0"))₫</span>
                        </div>
                        <div class="flex justify-between text-sm text-slate-500 font-medium">
                            <span>Phí vận chuyển</span>
                            <span class="text-green-600 font-bold italic">FREE</span>
                        </div>
                        <div class="pt-4 border-t border-slate-50 flex justify-between items-end">
                            <span class="text-xs font-black text-slate-400 uppercase">Tổng cộng</span>
                            <span class="text-3xl font-black text-primary summary-total">@(((decimal)(ViewBag.TongTien ?? 0m)).ToString("N0"))₫</span>
                        </div>
                    </div>

                    <a href="@Url.Action("ThanhToan", "GioHang")" class="w-full bg-primary text-white h-14 rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-red-200 hover:bg-primary-dark hover:-translate-y-1 transition-all flex items-center justify-center gap-3">
                        Tiến hành thanh toán
                        <i class="fa fa-chevron-right text-[10px]"></i>
                    </a>
                    
                    <div class="mt-6 flex items-center justify-center gap-4">
                        <img src="https://img.icons8.com/color/48/000000/visa.png" class="h-6 grayscale hover:grayscale-0 transition-all opacity-50">
                        <img src="https://img.icons8.com/color/48/000000/mastercard.png" class="h-6 grayscale hover:grayscale-0 transition-all opacity-50">
                        <img src="https://img.icons8.com/color/48/000000/google-pay.png" class="h-6 grayscale hover:grayscale-0 transition-all opacity-50">
                    </div>
                </div>
            </div>
        </div>
    }
</main>

@section scripts {
<script>
    function updateQuantity(id, change) {
        const itemRow = document.querySelector(`.cart-item[data-id="${id}"]`);
        const qtyEl = itemRow.querySelector('.qty-val');
        let currentQty = parseInt(qtyEl.innerText);
        let newQty = currentQty + change;
        
        if (newQty <= 0) {
            if (!confirm('Bạn muốn xóa sản phẩm này khỏi giỏ hàng?')) return;
        }

        fetch('@Url.Action("CapNhat", "GioHang")?id=' + id + '&sl=' + newQty, {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                if (newQty <= 0) {
                    location.reload();
                } else {
                    location.reload();
                }
            } else {
                showToast(data.message || 'Lỗi cập nhật!', 'error');
            }
        });
    }
</script>
}
