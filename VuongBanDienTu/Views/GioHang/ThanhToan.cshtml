@model IEnumerable<VuongBanDienTu.Models.GioHang>

@{
    ViewBag.Title = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var user = Session["TaiKhoan"] as VuongBanDienTu.Models.NguoiDung;
}

<div class="max-w-screen-xl mx-auto px-4 py-12">
    <div class="mb-12 text-center">
        <h1 class="text-4xl font-black text-slate-900 uppercase tracking-tight mb-2 italic">Hoàn tất đơn hàng</h1>
        <p class="text-sm text-slate-500 font-medium uppercase tracking-widest">Kiểm tra thông tin và xác nhận đặt hàng</p>
    </div>

    @using (Html.BeginForm("DatHang", "GioHang", FormMethod.Post))
    {
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- Information Section -->
            <div class="lg:col-span-7 space-y-10">
                <section>
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-6 flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-[10px] italic">01</span>
                        Thông tin giao hàng
                    </h3>
                    <div class="bg-white rounded-[2rem] border border-slate-100 p-8 shadow-sm space-y-6">
                        <div class="grid grid-cols-2 gap-6">
                            <div class="col-span-2">
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Họ và tên người nhận</label>
                                <input type="text" value="@user.HoTen" readonly class="w-full bg-slate-50 border-none rounded-xl px-4 py-3 text-sm font-bold text-slate-700 outline-none">
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Số điện thoại</label>
                                <input type="text" value="@user.SoDienThoai" readonly class="w-full bg-slate-50 border-none rounded-xl px-4 py-3 text-sm font-bold text-slate-700 outline-none">
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Email</label>
                                <input type="text" value="@user.Email" readonly class="w-full bg-slate-50 border-none rounded-xl px-4 py-3 text-sm font-bold text-slate-700 outline-none">
                            </div>
                            <div class="col-span-2">
                                <label class="block text-[10px] font-black text-primary uppercase tracking-widest mb-2">Địa chỉ nhận hàng *</label>
                                <textarea name="DiaChi" required class="w-full bg-slate-50 border-2 border-primary/10 focus:border-primary rounded-xl px-4 py-3 text-sm font-bold text-slate-800 outline-none transition-all h-24">@user.DiaChi</textarea>
                            </div>
                        </div>
                    </div>
                </section>

                <section>
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-6 flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-[10px] italic">02</span>
                        Phương thức thanh toán
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <label class="relative flex flex-col p-6 bg-white border-2 border-primary rounded-3xl cursor-pointer shadow-sm">
                            <input type="radio" name="Payment" value="COD" checked class="absolute top-4 right-4 accent-primary">
                            <i class="fa fa-truck text-2xl text-primary mb-3"></i>
                            <span class="text-sm font-bold text-slate-800">Thanh toán khi nhận hàng (COD)</span>
                            <span class="text-[10px] text-slate-400 mt-1">Đảm bảo an toàn, nhận hàng mới trả tiền</span>
                        </label>
                        <label class="relative flex flex-col p-6 bg-white border border-slate-100 rounded-3xl cursor-not-allowed opacity-50">
                            <input type="radio" name="Payment" disabled class="absolute top-4 right-4 text-slate-200">
                            <i class="fa fa-credit-card text-2xl text-slate-400 mb-3"></i>
                            <span class="text-sm font-bold text-slate-400">Chuyển khoản / Ví điện tử</span>
                            <span class="text-[10px] text-slate-400 mt-1 italic">Đang bảo trì...</span>
                        </label>
                    </div>
                </section>
            </div>

            <!-- Order Sidebar -->
            <div class="lg:col-span-5">
                <div class="sticky top-28 bg-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl">
                    <h3 class="text-xs font-black uppercase tracking-[0.2em] text-white/40 mb-8 border-b border-white/10 pb-4 italic">Đơn hàng của bạn</h3>
                    
                    <div class="space-y-6 max-h-[300px] overflow-y-auto scrollbar-hide mb-10">
                        @foreach (var item in Model)
                        {
                            <div class="flex gap-4 items-center">
                                <div class="w-16 h-16 rounded-2xl bg-white/5 p-2 flex-shrink-0">
                                    <img src="~/Content/Images/Products/@item.SanPham.AnhChinh" class="w-full h-full object-contain">
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs font-bold text-white line-clamp-1">@item.SanPham.TenSanPham</p>
                                    <p class="text-[10px] text-white/40 mt-1 uppercase">SL: @item.SoLuong | @item.SanPham.GiaBan.ToString("N0")₫</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-xs font-black text-gold">@(((item.SoLuong ?? 0) * item.SanPham.GiaBan).ToString("N0"))₫</p>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="space-y-4 mb-10 pt-6 border-t border-white/10">
                        <div class="flex justify-between items-center text-sm font-medium">
                            <span class="text-white/40">Tạm tính</span>
                            <span>@(((decimal)(ViewBag.TongTien ?? 0m)).ToString("N0"))₫</span>
                        </div>
                        <div class="flex justify-between items-center text-sm font-medium">
                            <span class="text-white/40">Vận chuyển</span>
                            <span class="text-green-400 italic">MIỄN PHÍ</span>
                        </div>
                        <div class="flex justify-between items-end pt-4 border-t border-white/20">
                            <span class="text-xs font-black uppercase tracking-widest text-gold italic">Tổng thanh toán</span>
                            <span class="text-3xl font-black text-white">@(((decimal)(ViewBag.TongTien ?? 0m)).ToString("N0"))₫</span>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-gold text-slate-900 h-16 rounded-[1.5rem] font-black uppercase tracking-widest shadow-xl shadow-gold/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                        <i class="fa fa-circle-check text-xl"></i>
                        XÁC NHẬN ĐẶT HÀNG
                    </button>
                    
                    <p class="text-[10px] text-center text-white/30 mt-6 px-10 leading-relaxed uppercase tracking-tighter">Bằng cách nhấn xác nhận, bạn đồng ý với các điều khoản bảo mật và chính sách mua hàng của VuongBanDienTu.</p>
                </div>
            </div>
        </div>
    }
</div>
