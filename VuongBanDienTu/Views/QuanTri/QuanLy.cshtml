@{
    Layout = "~/Views/Shared/_BoCucQuanTri.cshtml";
    ViewBag.Title = "Quản lý Sản phẩm & Doanh thu (Quản lý)";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h1 class="text-lg font-bold text-slate-800">@ViewBag.Title</h1>
        <p class="text-sm text-slate-500">Quản lý toàn bộ hàng hóa và hiệu suất của nhân viên.</p>
    </div>
    <div class="flex items-center gap-2">
        <button class="bg-white border border-slate-200 text-slate-600 px-4 py-2 rounded-xl text-xs font-bold hover:bg-slate-50 transition-all flex items-center gap-2">
            <i class="fa fa-download"></i> XUẤT BÁO CÁO
        </button>
        <button class="bg-primary text-white px-4 py-2 rounded-xl text-xs font-bold hover:bg-primary-dark transition-all flex items-center gap-2 shadow-lg shadow-red-200">
            <i class="fa fa-plus"></i> THÊM SẢN PHẨM
        </button>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <!-- Danh sách sản phẩm -->
    <div class="xl:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <h3 class="font-bold text-slate-800">Danh sách sản phẩm</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-[10px] font-bold uppercase tracking-wider">
                        <th class="px-6 py-3">Sản phẩm</th>
                        <th class="px-6 py-3">Danh mục</th>
                        <th class="px-6 py-3">Giá bán</th>
                        <th class="px-6 py-3 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    <tr>
                        <td class="px-6 py-4 flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-slate-50 border border-slate-100 flex items-center justify-center p-1">
                                <i class="fa fa-tv text-slate-400"></i>
                            </div>
                            <span class="font-bold text-slate-800">Samsung Crystal UHD 55"...</span>
                        </td>
                        <td class="px-6 py-4 text-slate-500 text-xs">Tivi</td>
                        <td class="px-6 py-4 font-black text-slate-800">11,290,000đ</td>
                        <td class="px-6 py-4 text-right">
                            <button class="text-slate-400 hover:text-primary transition-colors mx-1"><i class="fa fa-edit"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Doanh thu tuần -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
        <h3 class="font-bold text-slate-800 mb-6 flex items-center justify-between">
            Doanh thu tuần này
            <span class="text-[10px] text-green-500">+15.4%</span>
        </h3>
        <div class="flex items-end gap-2 h-32 mb-4 px-2">
            <div class="bg-slate-100 w-full h-[40%] rounded-t-md"></div>
            <div class="bg-slate-100 w-full h-[60%] rounded-t-md"></div>
            <div class="bg-primary w-full h-[75%] rounded-t-md shadow-lg shadow-red-100"></div>
        </div>
    </div>
</div>
