<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Vuong Ban Dien Tu - Dien may gia tot, uy tin hang dau Viet Nam" />
    <title>@ViewBag.Title - VuongBanDienTu</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#e8192c',
                        'primary-dark': '#c0001a',
                        'primary-light': '#ff4444',
                        gold: '#ffe000',
                        navy: '#1565c0',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    animation: {
                        'pulse-cta': 'pulse-cta 2s ease-in-out infinite',
                    },
                    keyframes: {
                        'pulse-cta': {
                            '0%, 100%': { boxShadow: '0 4px 16px rgba(232,25,44,0.5)' },
                            '50%': { boxShadow: '0 4px 28px rgba(232,25,44,0.85)' },
                        }
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Carousel */
        .hero-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.6s ease; }
        .hero-slide.active { opacity: 1; }
        /* Sidebar hover */
        .cat-item:hover { background: #fff5f5; color: #e8192c; }
        /* Product card img zoom */
        .prod-card:hover img { transform: scale(1.05); }
        /* Floating CTA pulse */
        .cta-pulse { animation: pulse-cta 2s ease-in-out infinite; }
        @@keyframes pulse-cta {
            0%, 100% { box-shadow: 0 4px 16px rgba(232,25,44,0.5); }
            50% { box-shadow: 0 4px 30px rgba(232,25,44,0.9); }
        }
        /* line-clamp for product name */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        /* Hide scrollbar for Chrome, Safari and Opera */
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        /* Hide scrollbar for IE, Edge and Firefox */
        .scrollbar-hide {
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 text-sm">

    <!-- ===================== HEADER ===================== -->
    <header class="bg-primary sticky top-0 z-50 shadow-lg">
        <div class="max-w-screen-xl mx-auto px-3 py-2 flex items-center gap-3">

            <!-- Logo -->
            <a href="/" class="flex-shrink-0">
                <span class="text-xl sm:text-2xl font-black italic text-white tracking-tight">
                    <span class="text-gold">VUONG</span>BANDIENTU
                </span>
            </a>

            <!-- Location -->
            <div class="hidden sm:flex flex-col flex-shrink-0 cursor-pointer text-white leading-tight">
                <span class="text-[9px] opacity-80">Xem giá tại</span>
                <span class="text-xs font-bold border-b border-dashed border-white/50">
                    <i class="fa fa-map-marker-alt mr-1"></i>Hà Nội <i class="fa fa-caret-down"></i>
                </span>
            </div>

            <!-- Search - Visible on Desktop, Hidden on Mobile (will show in second row) -->
            <form class="hidden lg:flex flex-1 h-9 rounded overflow-hidden shadow-md" action="#" method="get">
                <input
                    type="text" name="q"
                    placeholder="Bạn cần tìm gì hôm nay?"
                    class="flex-1 px-3 text-sm outline-none text-gray-700"
                />
                <button type="submit" class="bg-red-900 hover:bg-red-800 text-white px-4 transition-colors">
                    <i class="fa fa-search"></i>
                </button>
            </form>

            <!-- Actions -->
            <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
                @{
                    var cart = Session["GioHang"] as List<VuongBanDienTu.Models.GioHang>;
                    int count = cart != null ? (int)cart.Sum(n => n.SoLuong) : 0;
                }
                <a href="@Url.Action("Index", "GioHang")" onclick="if(@count == 0) { showToast('Không có sản phẩm nào trong giỏ hàng!', 'warning'); return false; }" class="flex flex-col items-center text-white hover:opacity-80 transition-opacity relative group">
                    <span class="text-xl relative">
                        <i class="fa fa-shopping-cart"></i>
                        <span id="cart-count" class="absolute -top-1.5 -right-2 bg-gold text-gray-900 text-[9px] font-bold rounded-full w-4 h-4 flex items-center justify-center">@count</span>
                    </span>
                    <span class="text-[10px]">Giỏ hàng</span>
                </a>
                <a href="@Url.Action("Index", "DonHang")" class="flex flex-col items-center text-white hover:opacity-80 transition-opacity">
                    <i class="fa fa-clipboard-list text-xl"></i>
                    <span class="text-[10px]">Tra cứu đơn</span>
                </a>
                @if (Session["TaiKhoan"] != null)
                {
                    var user = (VuongBanDienTu.Models.NguoiDung)Session["TaiKhoan"];
                    <div class="relative group">
                        <button class="flex flex-col items-center text-white hover:opacity-80 transition-opacity">
                            <i class="fa fa-user-check text-xl text-gold"></i>
                            <span class="text-[10px] truncate max-w-[80px]">Hi, @user.HoTen.Split(' ').Last()</span>
                        </button>
                        <!-- Dropdown -->
                        <div class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-slate-100 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-[60]">
                            <div class="px-4 py-2 border-b border-slate-50 mb-1">
                                <p class="text-[10px] font-bold text-slate-400 uppercase">Tài khoản của tôi</p>
                                <p class="text-xs font-bold text-slate-800 truncate">@user.HoTen</p>
                            </div>
                            @if (user.MaVaiTro == 1 || user.MaVaiTro == 2 || user.MaVaiTro == 3)
                            {
                                <a href="@Url.Action("TongQuan", "QuanTri")" class="flex items-center gap-2 px-4 py-2 text-xs text-slate-600 hover:bg-slate-50 hover:text-primary transition-colors">
                                    <i class="fa fa-gauge-high w-4"></i> Trang quản trị
                                </a>
                            }
                            <a href="#" class="flex items-center gap-2 px-4 py-2 text-xs text-slate-600 hover:bg-slate-50 hover:text-primary transition-colors">
                                <i class="fa fa-box-open w-4"></i> Đơn hàng của tôi
                            </a>
                            <a href="@Url.Action("DangXuat", "TaiKhoan")" class="flex items-center gap-2 px-4 py-2 text-xs text-primary font-bold hover:bg-red-50 transition-colors mt-1 border-t border-slate-50 pt-2">
                                <i class="fa fa-right-from-bracket w-4"></i> Đăng xuất
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="javascript:void(0)" onclick="showAuthModal('login')" class="flex flex-col items-center text-white hover:opacity-80 transition-opacity">
                        <i class="fa fa-user text-xl"></i>
                        <span class="text-[10px]">Tài khoản</span>
                    </a>
                }
                <div class="hidden sm:flex flex-col items-center text-white flex-shrink-0">
                    <i class="fa fa-phone text-base"></i>
                    <span class="text-sm font-bold">1800.6800</span>
                    <span class="text-[9px] opacity-80">Miễn phí</span>
                </div>
            </div>
        </div>

        <!-- Mobile Search - Visible on Small Screens only -->
        <div class="lg:hidden px-3 pb-2 pt-1 border-t border-white/10">
            <form class="flex h-9 rounded overflow-hidden shadow-md bg-white" action="#" method="get">
                <input
                    type="text" name="q"
                    placeholder="Bạn cần tìm gì hôm nay?"
                    class="flex-1 px-3 text-sm outline-none text-gray-700"
                />
                <button type="submit" class="bg-red-900 text-white px-4">
                    <i class="fa fa-search"></i>
                </button>
            </form>
        </div>
    </header>

    <!-- ===================== SECONDARY NAV ===================== -->
    <nav class="bg-white border-b-2 border-primary">
        <div class="max-w-screen-xl mx-auto flex items-stretch">
            <div class="relative flex-shrink-0 group-category">
                <button id="categoryBtn" class="bg-primary text-white flex items-center gap-2 px-3 sm:px-4 h-full font-bold text-xs sm:text-sm min-w-[120px] sm:min-w-[190px] whitespace-nowrap select-none hover:bg-primary-dark transition-colors">
                    <i class="fa fa-bars"></i>
                    <span>Danh mục <span class="hidden sm:inline">sản phẩm</span></span>
                </button>
                <!-- Category Dropdown -->
                <div id="categoryDropdown" class="absolute left-0 top-full mt-0.5 z-[70] opacity-0 invisible translate-y-2 transition-all duration-200">
                    @try {
                        @Html.Action("CategoryMenu", "Menu")
                    } catch (Exception ex) {
                        <div class="p-4 bg-white shadow-xl rounded-xl text-xs text-red-500">
                            <i class="fa fa-exclamation-triangle"></i> Lỗi tải danh mục. Vui lòng rebuild lại dự án.
                        </div>
                    }
                </div>
            </div>
            <!-- flex-1 min-w-0 + flex-nowrap: essential for overflow-x-auto in flexbox -->
            <div class="flex items-center flex-nowrap overflow-x-auto flex-1 min-w-0 scrollbar-hide">
                <a href="#" class="flex items-center gap-1.5 px-3 py-2.5 text-xs font-semibold text-gray-700 whitespace-nowrap border-b-2 border-transparent hover:text-primary hover:border-primary transition-all flex-shrink-0">
                    <i class="fa fa-fire text-orange-500"></i> Cẩm nang khuyến mại
                </a>
                <a href="#" class="flex items-center gap-1.5 px-3 py-2.5 text-xs font-semibold text-gray-700 whitespace-nowrap border-b-2 border-transparent hover:text-primary hover:border-primary transition-all flex-shrink-0">
                    <i class="fa fa-truck text-blue-500"></i> Giao lắp, bảo hành chuyên nghiệp
                </a>
                <a href="#" class="flex items-center gap-1.5 px-3 py-2.5 text-xs font-semibold text-gray-700 whitespace-nowrap border-b-2 border-transparent hover:text-primary hover:border-primary transition-all flex-shrink-0">
                    <i class="fa fa-gift text-red-500"></i> Tổng hợp khuyến mại
                </a>
                <a href="#" class="flex items-center gap-1.5 px-3 py-2.5 text-xs font-semibold text-gray-700 whitespace-nowrap border-b-2 border-transparent hover:text-primary hover:border-primary transition-all flex-shrink-0">
                    <i class="fa fa-briefcase text-gray-600"></i> Bán hàng doanh nghiệp
                </a>
            </div>
        </div>
    </nav>

    <!-- ===================== BODY ===================== -->
    <main>
        @RenderBody()
    </main>

    @Html.Partial("_ThongBaoToast")

    <!-- ===================== FOOTER ===================== -->
    <footer class="bg-gray-900 text-gray-400 pt-8 pb-4 mt-6">
        <div class="max-w-screen-xl mx-auto px-3 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <div>
                <div class="text-2xl font-black italic text-white mb-3">
                    <span class="text-gold">VUONG</span>BANDIENTU
                </div>
                <p class="text-xs leading-relaxed">Chuyên cung cấp sản phẩm điện tử, điện máy chính hãng với giá tốt nhất thị trường. Cam kết uy tín, dịch vụ tận tâm.</p>
            </div>
            <div>
                <h4 class="text-white text-xs font-bold uppercase mb-3">Hỗ trợ khách hàng</h4>
                <ul class="space-y-2 text-xs">
                    <li><a href="#" class="hover:text-white transition-colors">Hướng dẫn đặt hàng</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Chính sách đổi trả</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Chính sách bảo hành</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Phương thức thanh toán</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Tra cứu đơn hàng</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-white text-xs font-bold uppercase mb-3">Về chúng tôi</h4>
                <ul class="space-y-2 text-xs">
                    <li><a href="#" class="hover:text-white transition-colors">Giới thiệu</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Tuyển dụng</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Tin tức</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Hệ thống siêu thị</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-white text-xs font-bold uppercase mb-3">Liên hệ</h4>
                <ul class="space-y-2 text-xs">
                    <li><a href="#" class="hover:text-white transition-colors"><i class="fa fa-phone w-4 mr-1"></i>1800.6800 (Miễn phí)</a></li>
                    <li><a href="#" class="hover:text-white transition-colors"><i class="fa fa-envelope w-4 mr-1"></i>support@vuongbdt.vn</a></li>
                    <li><a href="#" class="hover:text-white transition-colors"><i class="fa fa-map-marker-alt w-4 mr-1"></i>Hà Nội, Việt Nam</a></li>
                </ul>
            </div>
        </div>
        <div class="max-w-screen-xl mx-auto px-3 mt-6 pt-4 border-t border-gray-700 text-center text-xs text-gray-600">
            &copy; @DateTime.Now.Year VuongBanDienTu. All rights reserved.
        </div>
    </footer>

    <!-- Floating CTA -->
    <button class="cta-pulse fixed bottom-6 right-6 z-50 bg-primary text-white font-bold text-sm px-5 py-3 rounded-full flex items-center gap-2 border-none cursor-pointer">
        <i class="fa fa-phone"></i> Mua ngay 1800.6800
    </button>

    <!-- Cart Notification Modal -->
    <div id="cartModal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/80 opacity-0 invisible transition-[opacity,visibility] duration-300">
        <div class="bg-white rounded-[2.5rem] shadow-2xl max-w-sm w-full overflow-hidden transform scale-95 opacity-0 transition-[transform,opacity] duration-300" id="cartModalContent">
            <div class="p-8 text-center">
                <div class="w-16 h-16 bg-green-50 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fa fa-check text-3xl"></i>
                </div>
                <h3 class="text-xl font-black text-slate-800 mb-2">Thành công!</h3>
                <p class="text-slate-500 text-sm mb-8">Sản phẩm đã được thêm vào giỏ hàng của bạn.</p>
                
                <div class="space-y-3">
                    <a href="@Url.Action("Index", "GioHang")" class="block w-full py-4 bg-primary text-white rounded-2xl font-black uppercase tracking-widest hover:bg-primary-dark transition-all shadow-lg shadow-red-100">
                        Xem giỏ hàng
                    </a>
                    <button onclick="closeCartModal()" class="block w-full py-4 bg-slate-50 text-slate-400 rounded-2xl font-bold uppercase tracking-widest hover:bg-slate-100 transition-all">
                        Tiếp tục mua sắm
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Auth Modal (Login/Register) -->
    <div id="authModal" class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-slate-900/80 opacity-0 invisible transition-[opacity,visibility] duration-300">
        <div class="bg-white rounded-[2.5rem] shadow-2xl max-w-md w-full overflow-hidden transform scale-95 opacity-0 transition-[transform,opacity] duration-300" id="authModalContent">
            <div class="p-8 sm:p-10">
                <!-- Close Button -->
                <button onclick="closeAuthModal()" class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center rounded-full bg-slate-50 text-slate-400 hover:text-primary hover:bg-red-50 transition-all">
                    <i class="fa fa-times"></i>
                </button>

                <!-- Tabs -->
                <div class="flex justify-center gap-8 mb-8 border-b border-slate-100">
                    <button id="tab-login" onclick="switchAuthTab('login')" class="pb-3 text-sm font-black uppercase tracking-widest transition-all border-b-2 border-transparent text-slate-400">Đăng nhập</button>
                    <button id="tab-register" onclick="switchAuthTab('register')" class="pb-3 text-sm font-black uppercase tracking-widest transition-all border-b-2 border-transparent text-slate-400">Đăng ký</button>
                </div>

                <div id="auth-error" class="hidden mb-6 bg-red-50 border border-red-100 text-primary px-4 py-3 rounded-xl text-xs font-bold items-center gap-2">
                    <i class="fa fa-circle-exclamation"></i>
                    <span id="auth-error-msg"></span>
                </div>

                <!-- Login Form -->
                <form id="loginForm" onsubmit="handleAuthSubmit(event, 'login')" class="space-y-4">
                    <div class="relative group">
                        <i class="fa fa-user absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-primary transition-all"></i>
                        <input type="text" name="TenDangNhap" required placeholder="Tên đăng nhập" class="w-full pl-12 pr-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold">
                    </div>
                    <div class="relative group">
                        <i class="fa fa-lock absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-primary transition-all"></i>
                        <input type="password" name="MatKhau" required placeholder="Mật khẩu" class="w-full pl-12 pr-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold">
                    </div>
                    <button type="submit" class="w-full py-4 bg-primary text-white rounded-2xl font-black uppercase tracking-widest shadow-lg shadow-red-100 hover:bg-primary-dark hover:-translate-y-0.5 transition-all">
                        Đăng nhập
                    </button>
                </form>

                <!-- Register Form -->
                <form id="registerForm" onsubmit="handleAuthSubmit(event, 'register')" class="hidden space-y-4">
                    <div class="relative group">
                        <i class="fa fa-user absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-primary transition-all"></i>
                        <input type="text" name="TenDangNhap" required placeholder="Tên đăng nhập" class="w-full pl-12 pr-6 py-3.5 bg-slate-50 border-2 border-transparent rounded-xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm">
                    </div>
                    <div class="relative group">
                        <i class="fa fa-lock absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-primary transition-all"></i>
                        <input type="password" name="MatKhau" required placeholder="Mật khẩu" class="w-full pl-12 pr-6 py-3.5 bg-slate-50 border-2 border-transparent rounded-xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm">
                    </div>
                    <div class="relative group">
                        <i class="fa fa-id-card absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-primary transition-all"></i>
                        <input type="text" name="HoTen" required placeholder="Họ và tên" class="w-full pl-12 pr-6 py-3.5 bg-slate-50 border-2 border-transparent rounded-xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm">
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <input type="email" name="Email" required placeholder="Email" class="w-full px-5 py-3.5 bg-slate-50 border-2 border-transparent rounded-xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm">
                        <input type="tel" name="SoDienThoai" required placeholder="SĐT" class="w-full px-5 py-3.5 bg-slate-50 border-2 border-transparent rounded-xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm">
                    </div>
                    <button type="submit" class="w-full py-4 bg-primary text-white rounded-2xl font-black uppercase tracking-widest shadow-lg shadow-red-100 hover:bg-primary-dark transition-all">
                        Đăng ký ngay
                    </button>
                </form>

                <div class="mt-8 text-center">
                    <p id="auth-switch-prompt" class="text-xs text-slate-400 font-bold uppercase tracking-widest">
                        Chưa có tài khoản? <button onclick="switchAuthTab('register')" class="text-primary hover:underline">Đăng ký ngay</button>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showAuthModal(tab = 'login') {
            const modal = document.getElementById('authModal');
            const content = document.getElementById('authModalContent');
            modal.classList.remove('invisible', 'opacity-0');
            modal.classList.add('opacity-100');
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
            document.body.style.overflow = 'hidden';
            switchAuthTab(tab);
        }

        function closeAuthModal() {
            const modal = document.getElementById('authModal');
            const content = document.getElementById('authModalContent');
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            document.body.style.overflow = '';
            setTimeout(() => {
                modal.classList.add('invisible');
                document.getElementById('auth-error').classList.add('hidden');
            }, 300);
        }

        function switchAuthTab(tab) {
            const isLogin = tab === 'login';
            document.getElementById('loginForm').classList.toggle('hidden', !isLogin);
            document.getElementById('registerForm').classList.toggle('hidden', isLogin);
            
            const loginTab = document.getElementById('tab-login');
            const registerTab = document.getElementById('tab-register');
            
            if (isLogin) {
                loginTab.classList.add('text-primary', 'border-primary');
                loginTab.classList.remove('text-slate-400', 'border-transparent');
                registerTab.classList.remove('text-primary', 'border-primary');
                registerTab.classList.add('text-slate-400', 'border-transparent');
                document.getElementById('auth-switch-prompt').innerHTML = 'Chưa có tài khoản? <button onclick="switchAuthTab(\'register\')" class="text-primary hover:underline">Đăng ký ngay</button>';
            } else {
                registerTab.classList.add('text-primary', 'border-primary');
                registerTab.classList.remove('text-slate-400', 'border-transparent');
                loginTab.classList.remove('text-primary', 'border-primary');
                loginTab.classList.add('text-slate-400', 'border-transparent');
                document.getElementById('auth-switch-prompt').innerHTML = 'Đã có tài khoản? <button onclick="switchAuthTab(\'login\')" class="text-primary hover:underline">Đăng nhập ngay</button>';
            }
        }

        async function handleAuthSubmit(e, type) {
            e.preventDefault();
            const form = e.target;
            const formData = new FormData(form);
            const btn = form.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin mr-2"></i> Đang xử lý...';
            document.getElementById('auth-error').classList.add('hidden');

            const url = type === 'login' ? '@Url.Action("DangNhap", "TaiKhoan")' : '@Url.Action("DangKy", "TaiKhoan")';
            
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                
                if (data.success) {
                    if (type === 'login') {
                        window.location.href = data.redirect || '/';
                    } else {
                        showToast('Đăng ký thành công! Vui lòng đăng nhập.', 'success');
                        switchAuthTab('login');
                        form.reset();
                    }
                } else {
                    document.getElementById('auth-error').classList.remove('hidden');
                    document.getElementById('auth-error-msg').innerText = data.message;
                }
            } catch (err) {
                console.error(err);
                document.getElementById('auth-error').classList.remove('hidden');
                document.getElementById('auth-error-msg').innerText = 'Có lỗi kết nối, vui lòng thử lại.';
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        function showCartModal() {
            const modal = document.getElementById('cartModal');
            const content = document.getElementById('cartModalContent');
            modal.classList.remove('invisible', 'opacity-0');
            modal.classList.add('opacity-100');
            content.classList.remove('scale-100', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
            document.body.style.overflow = 'hidden';
        }

        function closeCartModal() {
            const modal = document.getElementById('cartModal');
            const content = document.getElementById('cartModalContent');
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            document.body.style.overflow = '';
            setTimeout(() => {
                modal.classList.add('invisible');
            }, 300);
        }

        function addToCart(id, event, isBuyNow = false) {
            if (event) {
                event.preventDefault();
                event.stopPropagation();
            }
            
            const qty = document.getElementById('buyQty')?.value || 1;
            
            // Visual feedback on button if present
            let btn = null;
            if (event && event.currentTarget) {
                btn = event.currentTarget;
            }

            const originalHTML = btn ? btn.innerHTML : '';
            if (btn && btn.tagName === 'BUTTON') {
                btn.disabled = true;
                btn.innerHTML = '<i class="fa fa-circle-notch fa-spin"></i>';
            }

            fetch('@Url.Action("Them", "GioHang")?id=' + id + '&sl=' + qty, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (isBuyNow) {
                        window.location.href = '@Url.Action("ThanhToan", "GioHang")';
                    } else {
                        // Update cart count in header
                        const cartCount = document.getElementById('cart-count');
                        if (cartCount) cartCount.innerText = data.totalItems;
                        
                        showCartModal();
                    }
                } else {
                    if (data.redirect) {
                        window.location.href = data.redirect;
                    } else {
                        showToast(data.message || 'Có lỗi xảy ra, vui lòng thử lại.', 'error');
                    }
                }
            })
            .catch(err => {
                console.error(err);
                showToast('Không thể kết nối tới máy chủ.', 'error');
            })
            .finally(() => {
                if (btn && btn.tagName === 'BUTTON') {
                    btn.disabled = false;
                    btn.innerHTML = originalHTML;
                }
            });
        }

        // Category Dropdown Toggle Logic
        const catBtn = document.getElementById('categoryBtn');
        const catDropdown = document.getElementById('categoryDropdown');
        
        if (catBtn && catDropdown) {
            catBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                const isVisible = !catDropdown.classList.contains('invisible');
                
                if (isVisible) {
                    closeCategoryDropdown();
                } else {
                    openCategoryDropdown();
                }
            });

            // Prevent closing when clicking inside
            catDropdown.addEventListener('click', function(e) {
                e.stopPropagation();
            });

            // Close when clicking outside
            document.addEventListener('click', function() {
                closeCategoryDropdown();
            });

            function openCategoryDropdown() {
                catDropdown.classList.remove('invisible', 'opacity-0', 'translate-y-2');
                catDropdown.classList.add('opacity-100', 'translate-y-0');
            }

            function closeCategoryDropdown() {
                catDropdown.classList.add('invisible', 'opacity-0', 'translate-y-2');
                catDropdown.classList.remove('opacity-100', 'translate-y-0');
            }
        }
    </script>
    @Scripts.Render("~/bundles/jquery")
    @RenderSection("scripts", required: false)
</body>
</html>
