@model IEnumerable<VuongBanDienTu.Models.DonHang>

@{
    ViewBag.Title = "Lịch sử mua hàng";
}

<div class="max-w-4xl mx-auto py-12 px-4">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-10">
        <div>
            <h2 class="text-3xl font-black text-slate-800 tracking-tight">Lịch sử mua hàng</h2>
            <p class="text-slate-400 font-medium mt-1">Danh sách tất cả các đơn hàng bạn đã đặt</p>
        </div>
        <a href="@Url.Action("Index", "DonHang")" class="px-6 py-3 bg-white border-2 border-slate-100 rounded-2xl font-black text-[10px] uppercase tracking-widest text-slate-400 hover:text-primary hover:border-primary/20 transition-all flex items-center gap-2">
            <i class="fa fa-search"></i> Tra cứu đơn khác
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="bg-white rounded-[2.5rem] border border-slate-100 p-16 text-center shadow-xl shadow-slate-100/50">
            <div class="w-24 h-24 bg-slate-50 text-slate-200 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fa fa-shopping-bag text-4xl"></i>
            </div>
            <h3 class="text-xl font-black text-slate-400 uppercase tracking-widest mb-4">Bạn chưa có đơn hàng nào</h3>
            <p class="text-slate-400 mb-8 max-w-xs mx-auto text-sm font-medium">Hãy tham khảo các sản phẩm tuyệt vời của chúng tôi và bắt đầu mua sắm ngay!</p>
            <a href="@Url.Action("Index", "SanPham")" class="inline-flex py-4 px-10 bg-primary text-white rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-red-100 hover:bg-primary-dark hover:-translate-y-1 transition-all">
                Khám phá sản phẩm
            </a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var item in Model)
            {
                <div class="bg-white rounded-[2rem] border border-slate-100 p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6 hover:shadow-xl hover:shadow-slate-200/40 transition-all duration-500 group">
                    <div class="w-16 h-16 bg-slate-50 text-slate-400 rounded-2xl flex items-center justify-center font-black text-xs rotate-0 group-hover:-rotate-6 transition-transform">
                        #@(Model.ToList().IndexOf(item) + 1)
                    </div>
                    <div class="flex-1 text-center sm:text-left">
                        <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-1">
                            <span class="text-sm font-black text-slate-800 uppercase tracking-tight">Đơn hàng #ORD-@item.MaDonHang</span>
                            @if (item.TrangThaiDonHang == "Chờ xử lý") {
                                <span class="w-fit mx-auto sm:mx-0 px-2 py-0.5 rounded-lg bg-amber-50 text-amber-600 text-[9px] font-black uppercase">Chờ xử lý</span>
                            } else if (item.TrangThaiDonHang == "Đã xác nhận") {
                                <span class="w-fit mx-auto sm:mx-0 px-2 py-0.5 rounded-lg bg-green-50 text-green-600 text-[9px] font-black uppercase">Đã xác nhận</span>
                            } else if (item.TrangThaiDonHang == "Đã hủy") {
                                <span class="w-fit mx-auto sm:mx-0 px-2 py-0.5 rounded-lg bg-red-50 text-primary text-[9px] font-black uppercase">Đã hủy</span>
                            }
                        </div>
                        <p class="text-xs text-slate-400 font-medium">Đặt ngày: @(item.NgayDat.HasValue ? item.NgayDat.Value.ToString("dd/MM/yyyy HH:mm") : "---")</p>
                    </div>
                    <div class="text-center sm:text-right">
                        <p class="text-lg font-black text-slate-800">@(item.TongTien.HasValue ? item.TongTien.Value.ToString("N0") : "0")₫</p>
                        <div class="flex flex-col items-center sm:items-end gap-1 mt-0.5">
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">@item.TrangThaiThanhToan</p>
                            @if (item.TrangThaiThanhToan == "Chưa thanh toán" && item.TrangThaiDonHang != "Đã hủy")
                            {
                                <button onclick="payNow(@item.MaDonHang)" class="px-3 py-1 bg-primary text-white text-[9px] font-black uppercase rounded-lg hover:bg-primary-dark transition-all shadow-md shadow-red-50">
                                    Thanh toán ngay
                                </button>
                            }
                        </div>
                    </div>
                    <div class="sm:pl-6 sm:border-l border-slate-50 w-full sm:w-auto">
                        <button onclick="window.location.href='@Url.Action("TimKiem", "DonHang", new { maDon = item.MaDonHang, sdt = (Session["TaiKhoan"] as VuongBanDienTu.Models.NguoiDung).SoDienThoai })'" 
                            class="w-full sm:w-12 h-12 rounded-2xl bg-slate-50 text-slate-400 hover:bg-primary/10 hover:text-primary transition-all flex items-center justify-center group/btn">
                            <i class="fa fa-chevron-right text-xs group-hover/btn:translate-x-1 transition-transform"></i>
                            <span class="sm:hidden ml-2 font-black uppercase text-[10px] tracking-widest">Xem chi tiết</span>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section scripts {
    <script>
        async function payNow(id) {
            if (!confirm('Xác nhận thanh toán ngay cho đơn hàng này?')) return;
            
            try {
                const response = await fetch('@Url.Action("XacNhanThanhToan", "DonHang")?id=' + id, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                if (data.success) {
                    showToast('Thanh toán thành công! Cảm ơn bạn.', 'success');
                    location.reload();
                } else {
                    showToast(data.message || 'Lỗi xử lý!', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Lỗi kết nối!', 'error');
            }
        }
    </script>
}
