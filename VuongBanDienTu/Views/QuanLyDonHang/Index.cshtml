@model IEnumerable<VuongBanDienTu.Models.DonHang>

@{
    Layout = "~/Views/Shared/_BoCucQuanTri.cshtml";
    ViewBag.Title = "Quản lý đơn hàng";
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <div>
            <h2 class="text-xl font-black text-slate-800">Quản lý Đơn hàng</h2>
            <p class="text-xs text-slate-400 font-medium">Theo dõi và xử lý đơn đặt hàng từ khách hàng</p>
        </div>
        <div class="flex items-center gap-3">
            <span class="text-xs font-bold text-slate-400">Bộ lọc:</span>
            <select class="bg-slate-50 border-none rounded-lg text-xs font-bold px-3 py-2 outline-none">
                <option>Tất cả đơn hàng</option>
                <option>Chờ xử lý</option>
                <option>Đã xác nhận</option>
                <option>Đã hủy</option>
            </select>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50">
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Mã Đơn</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Khách hàng</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Ngày đặt</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Tổng tiền</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Trạng thái</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="text-xs font-black text-slate-800 uppercase">#ORD-@item.MaDonHang</span>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm font-black text-slate-800">@(item.NguoiDung != null ? item.NguoiDung.HoTen : "Khách ẩn danh")</p>
                                <div class="flex flex-col gap-1 mt-1">
                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tight">Sản phẩm:</p>
                                    <div class="space-y-0.5">
                                        @foreach (var ct in item.ChiTietDonHangs)
                                        {
                                            <p class="text-[11px] font-bold text-slate-600 truncate max-w-[200px]">• @ct.SanPham.TenSanPham (@ct.SoLuong)</p>
                                        }
                                    </div>
                                    <p class="text-[10px] text-primary font-black mt-1">SĐT: @(item.NguoiDung != null ? item.NguoiDung.SoDienThoai : "---")</p>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-xs font-medium text-slate-500">
                                @(item.NgayDat.HasValue ? item.NgayDat.Value.ToString("dd/MM/yyyy HH:mm") : "---")
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm font-black text-slate-800">@(item.TongTien.HasValue ? item.TongTien.Value.ToString("N0") : "0")₫</span>
                                <div class="mt-1">
                                    @if (item.TrangThaiThanhToan == "Đã thanh toán") {
                                        <span class="text-[9px] font-black text-green-600 bg-green-50 px-1.5 py-0.5 rounded uppercase">Đã trả tiền</span>
                                    } else {
                                        <span class="text-[9px] font-black text-slate-400 bg-slate-50 px-1.5 py-0.5 rounded uppercase">Chưa trả tiền</span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                @if (item.TrangThaiDonHang != null && item.TrangThaiDonHang.Trim() == "Chờ xử lý")
                                {
                                    <span class="px-2.5 py-1 rounded-lg bg-amber-50 text-amber-600 text-[10px] font-black uppercase tracking-tight">Chờ xử lý</span>
                                }
                                else if (item.TrangThaiDonHang != null && item.TrangThaiDonHang.Trim() == "Đã xác nhận")
                                {
                                    <span class="px-2.5 py-1 rounded-lg bg-green-50 text-green-600 text-[10px] font-black uppercase tracking-tight">Đã xác nhận</span>
                                }
                                else if (item.TrangThaiDonHang != null && item.TrangThaiDonHang.Trim() == "Đã hủy")
                                {
                                    <div class="flex flex-col gap-1">
                                        <span class="w-fit px-2.5 py-1 rounded-lg bg-red-50 text-primary text-[10px] font-black uppercase tracking-tight">Đã hủy</span>
                                        @if (!string.IsNullOrEmpty(item.GhiChu))
                                        {
                                            <p class="text-[9px] text-slate-400 italic">Lý do: @item.GhiChu</p>
                                        }
                                    </div>
                                }
                                else if (item.TrangThaiDonHang != null)
                                {
                                    <span class="px-2.5 py-1 rounded-lg bg-slate-50 text-slate-600 text-[10px] font-black uppercase tracking-tight">@item.TrangThaiDonHang.Trim()</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    @if (item.TrangThaiDonHang != null && item.TrangThaiDonHang.Trim() == "Chờ xử lý")
                                    {
                                        <button onclick="approveOrder(@item.MaDonHang)" 
                                            class="px-3 py-1.5 rounded-lg text-[10px] font-black uppercase transition-all 
                                            @(item.TrangThaiThanhToan != null && item.TrangThaiThanhToan.Trim() == "Đã thanh toán" 
                                                ? "bg-green-600 text-white hover:bg-green-700 shadow-lg shadow-green-100 ring-4 ring-green-50" 
                                                : "bg-green-50 text-green-600 hover:bg-green-600 hover:text-white")">
                                            Duyệt đơn @(item.TrangThaiThanhToan != null && item.TrangThaiThanhToan.Trim() == "Đã thanh toán" ? "ngay" : "")
                                        </button>
                                        <button onclick="openCancelModal(@item.MaDonHang)" class="px-3 py-1.5 rounded-lg bg-red-50 text-primary text-[10px] font-black uppercase hover:bg-primary hover:text-white transition-all">
                                            Hủy
                                        </button>
                                    }
                                    else if (item.TrangThaiThanhToan != null && item.TrangThaiThanhToan.Trim() == "Đã thanh toán" && item.TrangThaiDonHang != "Đã xác nhận" && item.TrangThaiDonHang != "Đã hủy")
                                    {
                                        <button onclick="approveOrder(@item.MaDonHang)" class="px-3 py-1.5 rounded-lg bg-green-600 text-white text-[10px] font-black uppercase hover:bg-green-700 transition-all shadow-lg shadow-green-100 ring-4 ring-green-50">
                                            Duyệt đơn ngay
                                        </button>
                                    }
                                    <button onclick="openDetailsModal(@item.MaDonHang)" class="w-8 h-8 rounded-lg bg-slate-50 text-slate-400 hover:bg-slate-200 transition-all flex items-center justify-center">
                                        <i class="fa fa-eye text-xs"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Chi Tiết Đơn Hàng -->
<div id="detailsModal" class="fixed inset-0 z-[120] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm opacity-0 invisible transition-all duration-300">
    <div class="bg-white rounded-[2.5rem] shadow-2xl max-w-2xl w-full overflow-hidden transform scale-95 transition-all duration-300" id="detailsContent">
        <!-- Nội dung AJAX sẽ tải vào đây -->
        <div class="p-20 text-center">
            <i class="fa fa-circle-notch fa-spin text-primary text-3xl mb-4"></i>
            <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Đang tải chi tiết...</p>
        </div>
    </div>
</div>

<!-- Modal Hủy Đơn -->
<div id="cancelModal" class="fixed inset-0 z-[120] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm opacity-0 invisible transition-all duration-300">
    <div class="bg-white rounded-[2rem] shadow-2xl max-w-md w-full overflow-hidden transform scale-95 transition-all duration-300" id="cancelContent">
        <div class="p-8">
            <h3 class="text-xl font-black text-slate-800 mb-2">Hủy đơn hàng</h3>
            <p class="text-xs text-slate-400 font-medium mb-6">Vui lòng nhập lý do hủy đơn hàng này</p>
            
            <input type="hidden" id="cancelOrderId">
            <textarea id="cancelReason" rows="4" class="w-full px-5 py-3.5 bg-slate-50 border-2 border-transparent rounded-2xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm resize-none mb-6" placeholder="Ví dụ: Khách gọi yêu cầu hủy, Hết hàng..."></textarea>
            
            <div class="flex gap-3">
                <button onclick="closeCancelModal()" class="flex-1 py-3 bg-slate-100 text-slate-600 rounded-xl font-black uppercase text-[10px] tracking-widest hover:bg-slate-200 transition-all">Đóng</button>
                <button onclick="submitCancelOrder()" class="flex-1 py-3 bg-primary text-white rounded-xl font-black uppercase text-[10px] tracking-widest hover:bg-primary-dark transition-all shadow-lg shadow-red-100">Xác nhận hủy</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        async function approveOrder(id) {
            if (!confirm('Bạn có chắc chắn muốn duyệt đơn hàng này? Hệ thống sẽ tự động trừ sản phẩm trong kho!')) return;
            
            try {
                const response = await fetch('@Url.Action("Duyet", "QuanLyDonHang")?id=' + id, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                if (data.success) {
                    location.reload();
                } else {
                    showToast(data.message || 'Lỗi xử lý!', 'error');
                }
            } catch (err) {
                showToast('Lỗi kết nối!', 'error');
            }
        }

        async function openDetailsModal(id) {
            const modal = document.getElementById('detailsModal');
            const content = document.getElementById('detailsContent');
            
            modal.classList.remove('invisible', 'opacity-0');
            modal.classList.add('opacity-100');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');

            try {
                const response = await fetch('@Url.Action("GetChiTiet", "QuanLyDonHang")?id=' + id);
                const html = await response.text();
                content.innerHTML = html;
            } catch (err) {
                content.innerHTML = '<div class="p-20 text-center text-primary font-black uppercase tracking-widest">Lỗi tải dữ liệu!</div>';
            }
        }

        function closeDetailsModal() {
            const modal = document.getElementById('detailsModal');
            const content = document.getElementById('detailsContent');
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('invisible');
                content.innerHTML = '<div class="p-20 text-center"><i class="fa fa-circle-notch fa-spin text-primary text-3xl mb-4"></i><p class="text-xs font-black text-slate-400 uppercase tracking-widest">Đang tải chi tiết...</p></div>';
            }, 300);
        }

        function openCancelModal(id) {
            document.getElementById('cancelOrderId').value = id;
            const modal = document.getElementById('cancelModal');
            const content = document.getElementById('cancelContent');
            modal.classList.remove('invisible', 'opacity-0');
            modal.classList.add('opacity-100');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
        }

        function closeCancelModal() {
            const modal = document.getElementById('cancelModal');
            const content = document.getElementById('cancelContent');
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('invisible');
                document.getElementById('cancelReason').value = '';
            }, 300);
        }

        async function submitCancelOrder() {
            const id = document.getElementById('cancelOrderId').value;
            const reason = document.getElementById('cancelReason').value;
            
            if (!reason) {
                showToast('Vui lòng nhập lý do hủy!', 'warning');
                return;
            }

            try {
                const response = await fetch('@Url.Action("Huy", "QuanLyDonHang")', {
                    method: 'POST',
                    body: new URLSearchParams({ id: id, lyDo: reason }),
                    headers: { 
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    }
                });
                const data = await response.json();
                if (data.success) {
                    showToast('Thao tác thành công!', 'success');
                    location.reload();
                } else {
                    showToast(data.message || 'Lỗi xử lý!', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Lỗi kết nối!', 'error');
            }
        }
    </script>
}
