@model VuongBanDienTu.Models.DonHang

<div class="p-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h3 class="text-xl font-black text-slate-800">Chi tiết đơn hàng #ORD-@Model.MaDonHang</h3>
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Đối soát tồn kho & xử lý</p>
        </div>
        <button onclick="closeDetailsModal()" class="w-10 h-10 rounded-full bg-slate-50 text-slate-400 hover:bg-slate-100 transition-all flex items-center justify-center">
            <i class="fa fa-times text-xs"></i>
        </button>
    </div>

    <div class="bg-slate-50 rounded-[2rem] border border-slate-100 overflow-hidden mb-8">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-100/50">
                    <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Sản phẩm</th>
                    <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Khách đặt</th>
                    <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Tồn kho</th>
                    <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Sau duyệt</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model.ChiTietDonHangs)
                {
                    var tonHienTai = item.SanPham.SoLuongTon ?? 0;
                    var sauDuyet = tonHienTai - item.SoLuong;
                    bool isWarning = tonHienTai < item.SoLuong;

                    <tr class="hover:bg-white transition-colors">
                        <td class="px-6 py-4 flex items-center gap-3">
                            <div class="w-10 h-10 bg-white rounded-lg border border-slate-200 overflow-hidden flex-shrink-0">
                                <img src="/Content/Images/Products/@item.SanPham.AnhChinh" class="w-full h-full object-cover">
                            </div>
                            <span class="text-xs font-bold text-slate-700 truncate max-w-[150px]">@item.SanPham.TenSanPham</span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-xs font-black text-slate-800">@item.SoLuong</span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-xs font-bold @(isWarning ? "text-primary bg-red-50" : "text-slate-500 bg-slate-100") px-2 py-0.5 rounded-md">
                                @tonHienTai
                            </span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-xs font-black @(sauDuyet < 0 ? "text-primary" : "text-green-600")">
                                @sauDuyet
                            </span>
                            @if (sauDuyet < 0)
                            {
                                <p class="text-[8px] font-black text-primary uppercase mt-1">Không đủ hàng!</p>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="flex items-center justify-between gap-4">
        <div class="flex-1">
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1">Phương thức thanh toán:</p>
            <p class="text-xs font-black text-slate-700">@Model.PhuongThucThanhToan - @Model.TrangThaiThanhToan</p>
        </div>
        <div class="flex items-center gap-3">
            @if (Model.TrangThaiDonHang != null && Model.TrangThaiDonHang.Trim() == "Chờ xử lý")
            {
                <button onclick="approveOrder(@Model.MaDonHang)" class="px-8 py-3 bg-green-600 text-white rounded-xl font-black uppercase text-[10px] tracking-widest hover:bg-green-700 transition-all shadow-lg shadow-green-100">
                    Xác nhận & Duyệt đơn
                </button>
            }
            <button onclick="closeDetailsModal()" class="px-8 py-3 bg-slate-100 text-slate-600 rounded-xl font-black uppercase text-[10px] tracking-widest hover:bg-slate-200 transition-all">
                Đóng
            </button>
        </div>
    </div>
</div>
