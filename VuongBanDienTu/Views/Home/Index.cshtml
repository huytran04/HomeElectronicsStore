@section scripts {
<script>
(function () {
    var slides = document.querySelectorAll('.hero-slide');
    var dots   = document.querySelectorAll('.dot');
    var current = 0, timer;

    function goTo(idx) {
        slides[current].classList.remove('active');
        dots[current].classList.replace('bg-white', 'bg-white/40');
        current = (idx + slides.length) % slides.length;
        slides[current].classList.add('active');
        dots[current].classList.replace('bg-white/40', 'bg-white');
    }

    function startAuto() { timer = setInterval(function(){ goTo(current + 1); }, 4000); }

    document.getElementById('carousel-next').addEventListener('click', function () { clearInterval(timer); goTo(current + 1); startAuto(); });
    document.getElementById('carousel-prev').addEventListener('click', function () { clearInterval(timer); goTo(current - 1); startAuto(); });
    dots.forEach(function (dot) {
        dot.addEventListener('click', function () { clearInterval(timer); goTo(+this.dataset.index); startAuto(); });
    });
    startAuto();
})();

(function () {
    var end = new Date(Date.now() + 9*3600000 + 59*60000 + 59000);
    function pad(n){ return (n<10?'0':'')+n; }
    function tick(){
        var d = Math.max(0, Math.floor((end - Date.now()) / 1000));
        document.getElementById('t-h').textContent = pad(Math.floor(d/3600));
        document.getElementById('t-m').textContent = pad(Math.floor((d%3600)/60));
        document.getElementById('t-s').textContent = pad(d%60);
        if(d>0) setTimeout(tick, 1000);
    }
    tick();
})();
</script>
}