@model IEnumerable<VuongBanDienTu.Models.SanPham>
@{
    ViewBag.Title = "Trang chủ";
}

<div class="max-w-screen-xl mx-auto px-3 pt-1.5 pb-3">

    <!-- ===================== HERO SECTION ===================== -->
    <!--
        Breakpoints:
        mobile       : carousel full width, no sidebar, no promo
        md (768px+)  : sidebar (160px) + carousel
        xl (1280px+) : sidebar (200px) + carousel + promo cards (220px)
    -->
    <section class="flex gap-2 mb-1.5 items-stretch">

        <!-- LEFT: Category Sidebar — hidden on mobile, shown md+ -->
        <aside class="hidden md:flex flex-col bg-white rounded-lg overflow-hidden shadow-sm flex-shrink-0 w-40 xl:w-52">
            <ul class="flex-1">
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in (IEnumerable<VuongBanDienTu.Models.DanhMuc>)ViewBag.Categories)
                    {
                        <li class="cat-item border-b border-gray-100 transition-colors hover:bg-red-50 hover:text-primary">
                            <a href="@Url.Action("Index", "SanPham", new { id = cat.MaDanhMuc })" class="flex items-center justify-between px-3 py-1.5 text-xs cursor-pointer">
                                <span class="flex items-center gap-1.5 min-w-0">
                                    <i class="fa fa-chevron-right text-primary w-3 flex-shrink-0 text-[8px]"></i>
                                    <span class="truncate">@cat.TenDanhMuc</span>
                                </span>
                                <i class="fa fa-chevron-right text-gray-400 text-[9px] flex-shrink-0 ml-1"></i>
                            </a>
                        </li>
                    }
                }
                else
                {
                    <li class="px-3 py-4 text-center text-[10px] text-slate-400">Đang cập nhật...</li>
                }
            </ul>
        </aside>

        <!-- CENTER: Hero Carousel — always visible, flex-1 takes remaining space -->
