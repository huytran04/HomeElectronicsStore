                            <div class="text-[11px] font-bold leading-tight my-1">Bravia 3 Tivi 55 Inch Google TV</div>
                            <span class="inline-block bg-navy text-white text-[9px] font-bold px-1.5 py-0.5 rounded mb-1">4K</span>
                            <div class="text-[10px] text-primary font-semibold">-17%</div>
                            <div class="text-[10px] text-gray-400 line-through">19.990.000₫</div>
                            <div class="text-base font-black text-primary">16.690.000₫</div>
