                            <div class="text-[11px] font-bold leading-tight my-1">Smart Tivi 55 Inch Crystal UHD</div>
                            <span class="inline-block bg-navy text-white text-[9px] font-bold px-1.5 py-0.5 rounded mb-1">4K</span>
                            <div class="text-[10px] text-primary font-semibold">-16%</div>
