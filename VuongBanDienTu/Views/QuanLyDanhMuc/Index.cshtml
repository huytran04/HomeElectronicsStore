@model IEnumerable<VuongBanDienTu.Models.DanhMuc>

@{
    Layout = "~/Views/Shared/_BoCucQuanTri.cshtml";
    ViewBag.Title = "Quản lý danh mục sản phẩm";
    var parentCats = ViewBag.ParentCategories as IEnumerable<VuongBanDienTu.Models.DanhMuc>;
}

<div class="space-y-6">
    <!-- Header Actions -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <div>
            <h2 class="text-xl font-black text-slate-800">Danh mục sản phẩm</h2>
            <p class="text-xs text-slate-400 font-medium">Phân loại sản phẩm theo nhóm và danh mục đa cấp</p>
        </div>
        <button onclick="openDanhMucModal()" class="bg-primary text-white px-6 py-3 rounded-xl font-black text-xs uppercase tracking-widest shadow-lg shadow-red-100 hover:bg-primary-dark hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2">
            <i class="fa fa-folder-plus text-sm"></i> Thêm danh mục mới
        </button>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50">
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">ID</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Tên danh mục</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Danh mục cha</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Mô tả</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Số sản phẩm</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-6 py-4 text-xs font-bold text-slate-400">#@item.MaDanhMuc</td>
                            <td class="px-6 py-4">
                                <span class="text-sm font-bold text-slate-800">@item.TenDanhMuc</span>
                            </td>
                            <td class="px-6 py-4">
                                @if (item.DanhMuc2 != null)
                                {
                                    <span class="px-2 py-1 rounded-lg bg-slate-100 text-slate-600 text-[10px] font-bold">@item.DanhMuc2.TenDanhMuc</span>
                                }
                                else
                                {
                                    <span class="text-[10px] text-slate-300 italic font-medium">Danh mục gốc</span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-xs text-slate-500 truncate max-w-[200px]">@(string.IsNullOrEmpty(item.MoTa) ? "---" : item.MoTa)</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-xs font-black text-primary bg-red-50 px-2 py-0.5 rounded-full">@item.SanPhams.Count</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button onclick="editDanhMuc(@item.MaDanhMuc, '@item.TenDanhMuc', '@item.MaDanhMucCha', '@item.MoTa')" class="w-8 h-8 rounded-lg bg-slate-50 text-slate-400 hover:bg-primary/10 hover:text-primary transition-all flex items-center justify-center">
                                        <i class="fa fa-edit text-xs"></i>
                                    </button>
                                    <button onclick="deleteDanhMuc(@item.MaDanhMuc)" class="w-8 h-8 rounded-lg bg-slate-50 text-slate-400 hover:bg-red-50 hover:text-primary transition-all flex items-center justify-center">
                                        <i class="fa fa-trash text-xs"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Category Modal -->
<div id="dmModal" class="fixed inset-0 z-[120] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm opacity-0 invisible transition-all duration-300">
    <div class="bg-white rounded-[2.5rem] shadow-2xl max-w-md w-full overflow-hidden transform scale-95 transition-all duration-300" id="dmModalContent">
        <div class="p-8 sm:p-10">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 id="modalTitle" class="text-2xl font-black text-slate-800">Thêm danh mục</h3>
                    <p class="text-xs text-slate-400 font-medium mt-1">Cấu trúc phân loại sản phẩm</p>
                </div>
                <button onclick="closeDanhMucModal()" class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-50 text-slate-400 hover:text-primary hover:bg-red-50 transition-all">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <form id="dmForm" onsubmit="handleDanhMucSubmit(event)" class="space-y-4">
                <input type="hidden" name="MaDanhMuc" id="MaDanhMuc" value="0">
                
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tên danh mục</label>
                    <input type="text" name="TenDanhMuc" id="TenDanhMuc" required class="w-full px-5 py-3.5 bg-slate-50 border-2 border-transparent rounded-2xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm" placeholder="VD: Tivi, Laptop...">
                </div>

                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Danh mục cha</label>
                    <div class="relative">
                        <select name="MaDanhMucCha" id="MaDanhMucCha" class="w-full px-5 py-3.5 bg-slate-50 border-2 border-transparent rounded-2xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm appearance-none">
                            <option value="">-- Là danh mục gốc --</option>
                            @foreach (var p in parentCats)
                            {
                                <option value="@p.MaDanhMuc">@p.TenDanhMuc</option>
                            }
                        </select>
                        <i class="fa fa-chevron-down absolute right-5 top-1/2 -translate-y-1/2 text-slate-300 text-[10px] pointer-events-none"></i>
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Mô tả</label>
                    <textarea name="MoTa" id="MoTa" rows="3" class="w-full px-5 py-3.5 bg-slate-50 border-2 border-transparent rounded-2xl outline-none focus:bg-white focus:border-primary/20 transition-all font-bold text-sm resize-none" placeholder="Nhập mô tả ngắn..."></textarea>
                </div>

                <div class="pt-6">
                    <button type="submit" class="w-full py-4 bg-primary text-white rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-red-100 hover:bg-primary-dark hover:-translate-y-1 transition-all flex items-center justify-center gap-3">
                        <span id="btnText">Lưu danh mục</span>
                        <i class="fa fa-arrow-right text-xs"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function openDanhMucModal() {
            document.getElementById('modalTitle').innerText = 'Thêm danh mục';
            document.getElementById('btnText').innerText = 'Lưu danh mục';
            document.getElementById('MaDanhMuc').value = '0';
            document.getElementById('dmForm').reset();
            
            const modal = document.getElementById('dmModal');
            const content = document.getElementById('dmModalContent');
            modal.classList.remove('invisible', 'opacity-0');
            modal.classList.add('opacity-100');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
            document.body.style.overflow = 'hidden';
        }

        function closeDanhMucModal() {
            const modal = document.getElementById('dmModal');
            const content = document.getElementById('dmModalContent');
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            document.body.style.overflow = '';
            setTimeout(() => {
                modal.classList.add('invisible');
            }, 300);
        }

        function editDanhMuc(id, name, parentId, desc) {
            openDanhMucModal();
            document.getElementById('modalTitle').innerText = 'Chỉnh sửa danh mục';
            document.getElementById('btnText').innerText = 'Cập nhật';
            document.getElementById('MaDanhMuc').value = id;
            document.getElementById('TenDanhMuc').value = name;
            document.getElementById('MaDanhMucCha').value = parentId === 'null' || !parentId ? '' : parentId;
            document.getElementById('MoTa').value = desc === 'null' || !desc ? '' : desc;
        }

        async function handleDanhMucSubmit(e) {
            e.preventDefault();
            const form = e.target;
            const formData = new FormData(form);
            const btn = form.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;

            btn.disabled = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin mr-2"></i> Đang xử lý...';

            try {
                const response = await fetch('@Url.Action("Luu", "QuanLyDanhMuc")', {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();

                if (data.success) {
                    showToast('Lưu danh mục thành công!', 'success');
                    location.reload();
                } else {
                    showToast(data.message || 'Có lỗi xảy ra!', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Có lỗi kết nối!', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        async function deleteDanhMuc(id) {
            if (!confirm('Bạn có chắc chắn muốn xóa danh mục này?')) return;

            try {
                const response = await fetch('@Url.Action("Xoa", "QuanLyDanhMuc")?id=' + id, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await response.json();
                if (data.success) {
                    showToast('Thao tác thành công!', 'success');
                    location.reload();
                } else {
                    showToast(data.message || 'Lỗi xử lý!', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Lỗi kết nối!', 'error');
            }
        }
    </script>
}
